# ============================================================
#  NEXUS AI BOT - Environment Configuration
#  Owner: TheMisfitDK (https://github.com/TheMisfitDK)
# ============================================================

# --- PLATFORM TOKENS ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here

# --- TELEGRAM USERBOT (optional — MTProto advanced features) ---
# Get from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=

# --- DATABASE ---
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/nexus-ai-bot

# --- AI PROVIDER KEYS ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=AIza...
GROQ_API_KEY=gsk_...
DEEPSEEK_API_KEY=sk-...
NVIDIA_API_KEY=nvapi-...
MISTRAL_API_KEY=...
COHERE_API_KEY=...
TOGETHER_API_KEY=...
HUGGINGFACE_API_KEY=hf_...
PERPLEXITY_API_KEY=pplx-...
XAI_API_KEY=xai-...  # Grok

# --- IMAGE GENERATION KEYS ---
STABILITY_API_KEY=sk-...        # Stability AI (SDXL, SD3, stable-image-ultra)
FAL_API_KEY=...                 # fal.ai (FLUX.1 schnell/realism)
# DALL-E uses OPENAI_API_KEY above
# Together image uses TOGETHER_API_KEY above
# HuggingFace image uses HUGGINGFACE_API_KEY above

# --- DEFAULT AI SETTINGS ---
DEFAULT_PROVIDER=groq
DEFAULT_MODEL=llama-3.3-70b-versatile
DEFAULT_MAX_TOKENS=2048
DEFAULT_TEMPERATURE=0.7

# --- IMAGE GENERATION SETTINGS ---
IMAGE_GEN_PROVIDER=stability    # stability | dalle | together | huggingface | fal

# --- APP CONFIG ---
NODE_ENV=production
PORT=3000
BOT_NAME=NexusAI

# --- OWNER IDENTITY (required for admin commands + unlimited access) ---
BOT_OWNER_ID=your_telegram_numeric_user_id
DISCORD_OWNER_ID=your_discord_numeric_user_id

# --- OWNER AUTHORIZATION SYSTEM ---
# Default token grant when authorizing a user without specifying an amount.
# Tokens are consumed per-message based on actual AI tokens used.
DEFAULT_TOKEN_GRANT=10000

# Pre-authorize users at boot (useful for Heroku/Railway where you can't run commands).
# Format: platform:userId:tokens  (tokens optional — uses DEFAULT_TOKEN_GRANT if omitted)
# Separate multiple entries with commas.
# Examples:
#    AUTHORIZED_USERS=telegram:123456789:5000
#    AUTHORIZED_USERS=telegram:123456789:5000,discord:987654321:10000
#    AUTHORIZED_USERS=telegram:123456789          (uses DEFAULT_TOKEN_GRANT)
AUTHORIZED_USERS=

# --- FEATURES ---
ENABLE_TELEGRAM=true
ENABLE_DISCORD=true
ENABLE_WEB_DASHBOARD=true

# --- RATE LIMITING ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20

# --- SECURITY ---
JWT_SECRET=your_super_secret_jwt_key_here

# --- LOGGING ---
LOG_LEVEL=info
