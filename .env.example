# ============================================================
#  NEXUS AI BOT - Environment Configuration
#  Owner: TheMisfitDK (https://github.com/TheMisfitDK)
# ============================================================

# --- PLATFORM TOKENS ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here

# --- DATABASE ---
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/nexus-ai-bot
REDIS_URL=redis://localhost:6379

# --- AI PROVIDER KEYS ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=AIza...
GROQ_API_KEY=gsk_...
DEEPSEEK_API_KEY=sk-...
NVIDIA_API_KEY=nvapi-...
MISTRAL_API_KEY=...
COHERE_API_KEY=...
TOGETHER_API_KEY=...
HUGGINGFACE_API_KEY=hf_...
PERPLEXITY_API_KEY=pplx-...
XAI_API_KEY=xai-...  # Grok

# --- DEFAULT AI SETTINGS ---
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o-mini
DEFAULT_MAX_TOKENS=2048
DEFAULT_TEMPERATURE=0.7

# --- APP CONFIG ---
NODE_ENV=production
PORT=3000
BOT_OWNER_ID=your_telegram_user_id
DISCORD_OWNER_ID=your_discord_user_id
BOT_NAME=NexusAI
BOT_USERNAME=nexusai_bot

# --- FEATURES ---
ENABLE_TELEGRAM=true
ENABLE_DISCORD=true
ENABLE_WEB_DASHBOARD=true
ENABLE_IMAGE_GEN=true
ENABLE_TTS=true
ENABLE_VOICE=true
ENABLE_PLUGINS=true

# --- RATE LIMITING ---
FREE_DAILY_MESSAGES=50
PRO_DAILY_MESSAGES=1000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20

# --- PAYMENTS (optional) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- SECURITY ---
JWT_SECRET=your_super_secret_jwt_key_here
ENCRYPTION_KEY=your_32_char_encryption_key_here

# --- LOGGING ---
LOG_LEVEL=info
LOG_TO_DB=true
